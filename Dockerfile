# पाइथनको एउटा स्टेबल भर्सन प्रयोग गर्ने
FROM python:3.10

# कन्टेनर भित्र 'code' भन्ने फोल्डर बनाउने
WORKDIR /code

# प्रोजेक्टका सबै फाइल र फोल्डरहरू कन्टेनरमा कपि गर्ने
COPY . .

# आवश्यक लाइब्रेरीहरू इन्स्टल गर्ने
RUN pip install --no-cache-dir -r requirements.txt

# रेल्वे वा हगिङ फेसमा पोर्ट ७८६० (वा ८०८०) मा चलाउन
# Gunicorn प्रयोग गर्दा एप छिटो र बलियो हुन्छ
CMD ["gunicorn", "-b", "0.0.0.0:7860", "app:app"]
